# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown files
[*.md]
indent_size = 4
trim_trailing_whitespace = false
max_line_length = off

# YAML files (GitHub Actions workflows)
[*.{yml,yaml}]
indent_size = 2
